# blacklight operator secrets — shell-sourceable template.
#
# Copy to .secrets/env, fill in ANTHROPIC_API_KEY, then `. .secrets/env`
# before `docker-compose up`. .secrets/env itself is gitignored; only this
# example template ships.

export ANTHROPIC_API_KEY='sk-ant-...'

# Managed Agents persistent IDs — leave unset on first run. The curator's
# managed_agents module will create the agent + environment and print the
# export lines to paste back here. Agents are reusable; create once per
# operator, not per session.
# export BL_CURATOR_AGENT_ID=agent_...
# export BL_CURATOR_ENV_ID=env_...

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/

# runtime data (curator)
curator/storage/evidence.db
curator/storage/evidence.db-journal
curator/storage/cases/*.yaml
curator/storage/work/
curator/storage/manifest.yaml
curator/storage/manifest.yaml.sha256

# logs (runtime); exhibits/**/*.log and tests/fixtures/*.log are committed demo fixtures
*.log
!exhibits/**/*.log
!tests/fixtures/*.log

# editor / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# env / secrets
.env
.env.*
!.env.example
.secrets/*
!.secrets/env.example

# operator-local collateral — class-clean directories, never surfaced to
# the public repo. Files live on disk for cross-reference grep; only the
# pathing classifies them as private.
#   docs/demo/      — storyboard, fixture spec, live-trace captures
#   docs/internal/  — PLAN.md, PIVOT-v2.md, install-validation, distilled API refs
#   docs/specs/     — per-milestone implementation specs
#   docs/plans/     — forward-looking planning notes
#   scripts/dev/    — build/synthesis helpers (fixture regenerators, etc.)
#   tools/dev/      — corpus orchestrators, large-scale fixture builders
#   pkg/test/       — packaging-pipeline test scaffolding
docs/demo/
docs/internal/
docs/specs/
docs/plans/
scripts/dev/
tools/dev/
pkg/test/

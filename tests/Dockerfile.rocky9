# tests/Dockerfile.rocky9 — blacklight test image (Rocky Linux 9)
# Layers blacklight runtime deps on the batsman rocky9 base image.
# Base already provides: bash findutils diffutils procps-ng gawk sed grep gzip tar wget curl ca-certificates util-linux hostname parallel bats-core, plus EPEL.
# Missing and required by blacklight: jq zstd ShellCheck.
ARG BASE_IMAGE=blacklight-base-rocky9
FROM ${BASE_IMAGE}

RUN microdnf install -y jq zstd ShellCheck patch cronie \
    httpd mod_security iptables nftables yara whois && microdnf clean all

# M6: mock LMD/ClamAV shims (see tests/Dockerfile for rationale)
RUN mkdir -p /usr/local/maldetect && \
    printf '#!/bin/bash\necho "maldet shim: ${*}"; exit 0\n' \
        > /usr/local/maldetect/maldet && \
    chmod +x /usr/local/maldetect/maldet && \
    printf '#!/bin/bash\necho "clamscan shim: ${*}"; exit 0\n' \
        > /usr/local/bin/clamscan && \
    printf '#!/bin/bash\necho "clamdscan shim: ${*}"; exit 0\n' \
        > /usr/local/bin/clamdscan && \
    chmod +x /usr/local/bin/clamscan /usr/local/bin/clamdscan

COPY tests/fixtures/defend-fp-corpus/ /var/lib/bl/fp-corpus/

COPY . /opt/blacklight-src
COPY tests/ /opt/tests/
COPY bl /opt/bl
COPY schemas/ /opt/schemas/
COPY prompts/ /opt/prompts/
COPY case-templates/ /opt/case-templates/
COPY skills/ /opt/skills/
RUN chmod +x /opt/bl

WORKDIR /opt/tests

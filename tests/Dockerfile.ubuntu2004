# tests/Dockerfile.ubuntu2004 — blacklight test image (Ubuntu 20.04)
# Layers blacklight runtime deps on the batsman ubuntu2004 base image.
# shellcheck excluded — Ubuntu 20.04 ships shellcheck 0.7.x which flags
# warnings the modern 0.9.x lanes (debian12 / rocky9 / ubuntu2404) don't.
# Project lint lanes are debian12 + rocky9 (CLAUDE.md); the test's
# shellcheck_available probe in tests/helpers/capability-detect.bash skips
# on this image when the binary is absent.
ARG BASE_IMAGE=blacklight-base-ubuntu2004
FROM ${BASE_IMAGE}

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
    jq zstd patch cron \
    apache2 libapache2-mod-security2 iptables nftables yara whois \
    && rm -rf /var/lib/apt/lists/*

# M6: mock LMD/ClamAV shims (see tests/Dockerfile for rationale)
RUN mkdir -p /usr/local/maldetect && \
    printf '#!/bin/bash\necho "maldet shim: ${*}"; exit 0\n' \
        > /usr/local/maldetect/maldet && \
    chmod +x /usr/local/maldetect/maldet && \
    printf '#!/bin/bash\necho "clamscan shim: ${*}"; exit 0\n' \
        > /usr/local/bin/clamscan && \
    printf '#!/bin/bash\necho "clamdscan shim: ${*}"; exit 0\n' \
        > /usr/local/bin/clamdscan && \
    chmod +x /usr/local/bin/clamscan /usr/local/bin/clamdscan

COPY tests/fixtures/defend-fp-corpus/ /var/lib/bl/fp-corpus/

COPY . /opt/blacklight-src
COPY tests/ /opt/tests/
COPY bl /opt/bl
COPY install.sh /opt/install.sh
COPY uninstall.sh /opt/uninstall.sh
COPY schemas/ /opt/schemas/
COPY prompts/ /opt/prompts/
COPY case-templates/ /opt/case-templates/
COPY skills/ /opt/skills/
COPY scripts/ /opt/scripts/
COPY skills-corpus/ /opt/skills-corpus/
COPY routing-skills/ /opt/routing-skills/
COPY Makefile /opt/Makefile
# M14 P7: bl-lmd-hook adapter
COPY files/ /opt/files/
RUN chmod +x /opt/bl /opt/scripts/dev/synth-corpus.sh /opt/scripts/dev/synthesize-fixture-logs.sh

WORKDIR /opt/tests

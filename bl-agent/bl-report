#!/bin/bash
#
# bl-report — tar suspicious findings + host state, POST to curator inbox.
#
# Collects:
#   - candidate suspicious paths (Day 2 scope: hunter-driven signal list)
#   - process snapshot, listening sockets, recent cron edits
#   - last N lines of relevant logs
# into a tarball, uploads to ${CURATOR_URL}/reports with X-Host-Id header.

set -euo pipefail

CURATOR_URL="${BL_CURATOR_URL:-http://bl-curator:8080}"
HOST_ID="${BL_HOST_ID:-$(command hostname -s)}"
REPORT_DIR="${BL_REPORT_DIR:-/var/bl-agent/reports}"

log() { command printf '[bl-report %s] %s\n' "$(command date -u +%Y-%m-%dT%H:%M:%SZ)" "$*" >&2; }

require() {
    local tool
    for tool in "$@"; do
        command -v "$tool" >/dev/null || { log "missing dependency: $tool"; exit 2; }
    done
}

main() {
    require curl tar du

    command mkdir -p "$REPORT_DIR"
    local ts
    ts=$(command date -u +%Y%m%dT%H%M%SZ)
    local report_id
    report_id="rpt-$(command printf '%s' "$HOST_ID-$ts" | command sha256sum | command cut -c1-8)"
    local tarball="$REPORT_DIR/report-${HOST_ID}-${ts}.tar.gz"

    local staging
    staging=$(command mktemp -d -t bl-report.XXXXXX)
    # shellcheck disable=SC2064  # expand $staging at trap-set time
    trap "command rm -rf '$staging'" EXIT

    command mkdir -p "$staging/fs" "$staging/logs" "$staging/cron" "$staging/procs"

    # Scope: operator-configurable paths. Defaults cover Magento hosting stack.
    local paths="${BL_REPORT_PATHS:-/var/www/html /var/log/apache2 /etc/cron.d}"
    local path_map_entries=""
    local p

    # shellcheck disable=SC2086  # intentional word-split on space-separated path list
    for p in $paths; do
        [[ -e "$p" ]] || continue  # skip missing paths silently
        local target_sub
        case "$p" in
            /var/www/*)       target_sub="fs" ;;
            /var/log/*)       target_sub="logs" ;;
            /etc/cron*)       target_sub="cron" ;;
            *)                target_sub="fs" ;;
        esac
        # Strip leading / so the tar entry is relative.
        local stripped="${p#/}"
        command mkdir -p "$staging/$target_sub/$(command dirname "$stripped")"
        # cp -a preserves mtimes — critical for timeline hunter
        command cp -a "$p" "$staging/$target_sub/$stripped" 2>/dev/null || continue  # silently drop unreadable
        path_map_entries="${path_map_entries}\"$target_sub/$stripped\":\"$p\","
    done

    # procs snapshot (unchanged Day 1 behavior)
    ps auxwwf > "$staging/procs/ps.txt" 2>/dev/null || true  # ps fails in some minimal containers
    ss -tlnp > "$staging/procs/sockets.txt" 2>/dev/null || true  # ss may be absent, non-fatal

    # Manifest envelope — parsed by curator.report_envelope.ReportEnvelope
    # Strip trailing comma from path_map_entries
    path_map_entries="${path_map_entries%,}"
    command cat > "$staging/manifest.json" <<EOF
{
  "report_id": "$report_id",
  "host_id": "$HOST_ID",
  "collected_at": "$(command date -u +%Y-%m-%dT%H:%M:%SZ)",
  "tool_version": "bl-report 0.2.0",
  "path_map": {${path_map_entries}}
}
EOF

    # Size guardrail — abort before transmit if staging exceeds cap.
    local max_mb="${BL_REPORT_MAX_MB:-50}"
    local actual_mb
    actual_mb=$(command du -sm "$staging" | command awk '{print $1}')
    if (( actual_mb > max_mb )); then
        log "staging exceeds BL_REPORT_MAX_MB=$max_mb (actual ${actual_mb}MB); aborting"
        exit 3
    fi

    command tar -C "$staging" -czf "$tarball" .

    log "uploading $tarball to $CURATOR_URL/reports"
    if ! curl -fsS -X POST \
        -H "X-Host-Id: $HOST_ID" \
        -H "Content-Type: application/x-tar" \
        --data-binary "@$tarball" \
        "$CURATOR_URL/reports" >/dev/null; then
        log "upload failed; preserving $tarball for retry"
        exit 1
    fi

    log "report accepted; removing local copy"
    command rm -f "$tarball"
}

main "$@"

#!/bin/bash
#
# bl-apply — read local manifest, filter by host stack profile, apply rules.
#
# Stack profile is detected at runtime (Apache+ModSec vs Nginx vs other).
# Rules that match the profile are written to the appropriate conf.d path.
# Rules that do not match are logged and skipped — this is the Day 4 demo
# moment where host-3 (Nginx) correctly skips a ModSec rule meant for host-2.

set -euo pipefail

MANIFEST_LOCAL="${BL_MANIFEST_LOCAL:-/var/bl-agent/manifest.yaml}"

log() { command printf '[bl-apply %s] %s\n' "$(command date -u +%Y-%m-%dT%H:%M:%SZ)" "$*" >&2; }

require() {
    local tool
    for tool in "$@"; do
        command -v "$tool" >/dev/null || { log "missing dependency: $tool"; exit 2; }
    done
}

detect_stack() {
    # BL_STACK_OVERRIDE allows test shims to inject a stack without binary detection.
    if [[ -n "${BL_STACK_OVERRIDE:-}" ]]; then
        command printf '%s\n' "$BL_STACK_OVERRIDE"
        return 0
    fi
    # Returns a short stack identifier on stdout. Checked against manifest
    # rule `applies_to` fields (Day 4).
    if command -v apache2 >/dev/null || command -v httpd >/dev/null; then
        if [[ -d /etc/modsecurity || -d /etc/modsecurity.d ]]; then
            command printf 'apache-modsec\n'
            return 0
        fi
        command printf 'apache\n'
        return 0
    fi
    if command -v nginx >/dev/null; then
        command printf 'nginx\n'
        return 0
    fi
    command printf 'unknown\n'
}

apply_rules() {
    local stack="$1"

    if [[ "$stack" == "nginx" || "$stack" == "unknown" ]]; then
        log "stack profile '$stack' — skipping Apache ruleset"
        return 0
    fi
    if [[ "$stack" != "apache" && "$stack" != "apache-modsec" ]]; then
        log "stack profile '$stack' not matched — skipping"
        return 0
    fi

    require yq apachectl

    local version
    version=$(yq '.version' "$MANIFEST_LOCAL")
    local rule_count
    rule_count=$(yq '.rules | length' "$MANIFEST_LOCAL")
    log "manifest v${version} carries ${rule_count} rule(s) for Apache profile"

    local rules_conf
    rules_conf="${BL_APACHE_CONF_AVAILABLE:-/etc/apache2/conf-available}/bl-rules-${version}.conf"
    local rules_enabled
    rules_enabled="${BL_APACHE_CONF_ENABLED:-/etc/apache2/conf-enabled}/bl-rules.conf"

    local tmpdir
    tmpdir=$(command mktemp -d -t bl-apply.XXXXXX)
    # shellcheck disable=SC2064  # expand $tmpdir at trap-set time so each invocation cleans its own dir
    trap "command rm -rf '$tmpdir'" RETURN

    : > "$tmpdir/rules.conf"
    local idx
    for (( idx=0; idx < rule_count; idx++ )); do
        local applies
        applies=$(yq ".rules[$idx].applies_to[]" "$MANIFEST_LOCAL" | command tr -d '"' | command paste -sd, -)
        case ",$applies," in
            *,apache,*|*,apache-modsec,*) ;;
            *) continue ;;
        esac
        yq ".rules[$idx].body" "$MANIFEST_LOCAL" >> "$tmpdir/rules.conf"
        command printf '\n' >> "$tmpdir/rules.conf"
    done

    # Capture prior symlink target so we can restore it if configtest fails
    # after we replace the live symlink below. Empty string = no prior link.
    local prev_target=""
    if [[ -L "$rules_enabled" ]]; then
        prev_target=$(command readlink "$rules_enabled")
    fi

    command install -D -m 0644 "$tmpdir/rules.conf" "$rules_conf"
    command ln -sf "$rules_conf" "$rules_enabled"

    if apachectl -t 2>"$tmpdir/configtest.err"; then
        log "apachectl -t PASS for manifest v${version}"
        return 0
    else
        local err_msg
        err_msg=$(command cat "$tmpdir/configtest.err")
        # Rollback: remove broken symlink + rules file before configtest diagnostic
        # can mask a real Apache reload. Restore prior target so the next unrelated
        # `systemctl reload apache2` sees the last-known-good ruleset, not a broken stub.
        command rm -f "$rules_enabled"
        if [[ -n "$prev_target" ]]; then
            command ln -sf "$prev_target" "$rules_enabled"
        fi
        command rm -f "$rules_conf"
        log "apachectl -t FAIL for manifest v${version}: ${err_msg}"
        log "rolled back — $rules_enabled restored to prior target: ${prev_target:-<none>}"
        return 3
    fi
}

main() {
    if [[ ! -r "$MANIFEST_LOCAL" ]]; then
        log "manifest not found at $MANIFEST_LOCAL — run bl-pull first"
        exit 1
    fi
    local stack
    stack=$(detect_stack)
    log "detected stack profile: $stack"
    apply_rules "$stack"
}

main "$@"

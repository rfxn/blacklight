[Unit]
Description=blacklight thin agent — pull/apply defense manifest, report to curator
Documentation=https://github.com/rfxn/blacklight
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
Environment=BL_CURATOR_URL=http://bl-curator:8080
ExecStart=/usr/local/sbin/bl-pull
ExecStart=/usr/local/sbin/bl-apply
ExecStart=/usr/local/sbin/bl-report
# Demo drives bl-pull/apply/report via `docker exec`; periodic-pull `.timer`
# wiring is a roadmap item in FUTURE.md, not shipped in this unit.

[Install]
WantedBy=multi-user.target

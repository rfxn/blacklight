    }
    local rc=0
    bl_api_call DELETE "/v1/sessions/$session_id/resources/$sesrsc_id" >/dev/null || rc=$?
    if (( rc == 0 )) || (( rc == 72 )); then
        return "$BL_EX_OK"
    fi
    return $rc

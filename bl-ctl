#!/bin/bash
#
# bl-ctl — operator view over the fleet. Thin wrapper around cat + grep +
# HTTP calls to the curator. Per HANDOFF scope: not a full CLI, just enough
# to surface manifest state and open cases for a human reading the output.

set -euo pipefail

CURATOR_URL="${BL_CURATOR_URL:-http://localhost:8080}"
CASES_DIR="${BL_CASES_DIR:-./curator/storage/cases}"

usage() {
    command cat <<'EOF'
bl-ctl — blacklight operator view

  bl-ctl status                show curator health + manifest version
  bl-ctl manifest              fetch current manifest
  bl-ctl cases                 list open cases
  bl-ctl case <CASE-YYYY-NNNN> dump one case file
  bl-ctl help                  this message
EOF
}

cmd_status() {
    curl -fsS "$CURATOR_URL/health" || { command printf 'curator unreachable at %s\n' "$CURATOR_URL"; exit 1; }
    command printf '\n'
}

cmd_manifest() {
    curl -fsS "$CURATOR_URL/manifest.yaml"
}

cmd_cases() {
    if [[ ! -d "$CASES_DIR" ]]; then
        command printf 'no cases dir at %s\n' "$CASES_DIR"
        exit 1
    fi
    command find "$CASES_DIR" -maxdepth 1 -name 'CASE-*.yaml' -type f -printf '%f\n' 2>/dev/null | command sort
}

cmd_case() {
    local case_id="${1:-}"
    if [[ -z "$case_id" ]]; then
        command printf 'bl-ctl case: case_id required\n' >&2
        exit 2
    fi
    local path="$CASES_DIR/${case_id}.yaml"
    if [[ ! -r "$path" ]]; then
        command printf 'case not found: %s\n' "$path" >&2
        exit 1
    fi
    command cat "$path"
}

main() {
    local subcommand="${1:-help}"
    shift || true  # argv exhausted on 0-arg invocation; safe.
    case "$subcommand" in
        status)   cmd_status   "$@" ;;
        manifest) cmd_manifest "$@" ;;
        cases)    cmd_cases    "$@" ;;
        case)     cmd_case     "$@" ;;
        help|-h|--help) usage ;;
        *)        command printf 'unknown subcommand: %s\n' "$subcommand" >&2; usage; exit 2 ;;
    esac
}

main "$@"

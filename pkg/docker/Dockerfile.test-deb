# blacklight DEB install verification — Debian 12
# Generated by pkg_gen.sh from pkg_lib templates, customized for single-binary layout
#
FROM debian:12

# Install runtime dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends bash coreutils curl jq && \
    rm -rf /var/lib/apt/lists/*

# Copy DEB and test script from build context
COPY blacklight_*.deb /tmp/
COPY test-pkg-install.sh /test/test-pkg-install.sh

# Install the package (use dpkg + apt fix-broken for dependency resolution)
RUN dpkg -i /tmp/blacklight_*.deb || apt-get install -f -y

CMD ["/test/test-pkg-install.sh", "deb"]

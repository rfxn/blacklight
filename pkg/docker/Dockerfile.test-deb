# blacklight DEB install verification
# BASE_IMAGE build arg allows testing on debian:12, ubuntu:24.04, etc.
#
ARG BASE_IMAGE=debian:12
FROM ${BASE_IMAGE}

# Install runtime dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends bash coreutils curl jq && \
    rm -rf /var/lib/apt/lists/*

# Re-enable doc installation — Docker Ubuntu base images exclude /usr/share/doc/*
# via /etc/dpkg/dpkg.cfg.d/ filters; remove the filter so our README.md lands.
RUN rm -f /etc/dpkg/dpkg.cfg.d/excludes 2>/dev/null || true  # no-op on debian:12

# Copy DEB and test script from build context
COPY blacklight_*.deb /tmp/
COPY test-pkg-install.sh /test/test-pkg-install.sh

# Install the package (use dpkg + apt fix-broken for dependency resolution)
RUN dpkg -i /tmp/blacklight_*.deb || apt-get install -f -y

CMD ["/test/test-pkg-install.sh", "deb"]

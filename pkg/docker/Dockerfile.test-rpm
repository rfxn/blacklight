# blacklight RPM install verification — Rocky 9
# Generated by pkg_gen.sh from pkg_lib templates, customized for single-binary layout
#
FROM rockylinux:9

# Install runtime dependencies
RUN dnf install -y --allowerasing bash coreutils curl jq && \
    dnf clean all

# Copy RPM and test script from build context
COPY blacklight-*el9*.rpm /tmp/
COPY test-pkg-install.sh /test/test-pkg-install.sh

# Install the package
RUN rpm -ivh /tmp/blacklight-*el9*.rpm

CMD ["/test/test-pkg-install.sh", "rpm"]

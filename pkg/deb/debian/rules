#!/usr/bin/make -f
# blacklight Debian rules — generated by pkg_gen.sh, customized for single-binary layout
#
%:
	dh $@

override_dh_auto_build:
	# Nothing to build — bl is a bash script
	:

override_dh_auto_install:
	set -e; \
	DESTDIR=debian/blacklight; \
	install -D -m 755 bl $${DESTDIR}/usr/bin/bl; \
	install -D -m 644 README.md $${DESTDIR}/usr/share/doc/blacklight/README.md; \
	install -D -m 644 CHANGELOG $${DESTDIR}/usr/share/doc/blacklight/CHANGELOG; \
	install -D -m 644 LICENSE $${DESTDIR}/usr/share/doc/blacklight/copyright; \
	install -d -m 750 $${DESTDIR}/var/lib/bl; \
	install -d -m 750 $${DESTDIR}/var/lib/bl/state; \
	install -d -m 750 $${DESTDIR}/var/lib/bl/ledger; \
	install -d -m 750 $${DESTDIR}/var/lib/bl/outbox

override_dh_fixperms:
	dh_fixperms
	chmod 750 debian/blacklight/var/lib/bl
	chmod 750 debian/blacklight/var/lib/bl/state
	chmod 750 debian/blacklight/var/lib/bl/ledger
	chmod 750 debian/blacklight/var/lib/bl/outbox

override_dh_compress:
	dh_compress -X README.md

override_dh_auto_test:
	# Skip — tests require privileged Docker environment

override_dh_auto_clean:
	# Nothing to clean
	:

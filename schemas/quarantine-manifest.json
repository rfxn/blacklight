{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rfxn.github.io/blacklight/schemas/quarantine-manifest.json",
  "title": "blacklight quarantine manifest sidecar",
  "type": "object",
  "required": [
    "entry_id",
    "original_path",
    "sha256",
    "size_bytes",
    "uid",
    "gid",
    "perms_octal",
    "mtime_epoch",
    "case_id",
    "reason",
    "iso_ts"
  ],
  "properties": {
    "entry_id": { "type": "string" },
    "original_path": { "type": "string" },
    "sha256": { "type": "string" },
    "size_bytes": { "type": "integer" },
    "uid": { "type": "integer" },
    "gid": { "type": "integer" },
    "perms_octal": { "type": "string" },
    "mtime_epoch": { "type": "integer" },
    "case_id": { "type": "string" },
    "reason": { "type": ["string", "null"] },
    "iso_ts": { "type": "string" }
  }
}

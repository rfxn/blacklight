{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rfxn.github.io/blacklight/schemas/ledger-entry.json",
  "title": "blacklight ledger record (JSONL line)",
  "type": "object",
  "required": ["ts", "case", "kind", "payload"],
  "properties": {
    "ts": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },
    "case": { "type": "string", "pattern": "^CASE-[0-9]{4}-[0-9]{4}$" },
    "kind": {
      "type": "string",
      "enum": [
        "defend_applied", "defend_rollback", "defend_refused",
        "defend_sig_rejected", "schema_reject", "unknown_tier_deny",
        "preflight_fail", "operator_decline", "step_run"
      ]
    },
    "payload": { "type": "object" }
  }
}
